{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Schema definition for validating wines",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "database-generated UUID for the wine record"
    },
    "created_at": {
      "type": "string",
      "description": "timestamp automatically generated by the database"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "color": {
      "type": "string",
      "enum": ["red", "white", "rose"]
    },
    "sparkling": {
      "type": "boolean"
    },
    "minerality": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "acidity": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "body": {
      "type": "string",
      "enum": ["light", "medium", "full"]
    },
    "tags": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": ["string", "null"]
      }
    },
    "vintage": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 9999,
      "description": "Four digit year"
    },
    "tasting_notes": {
      "type": ["string", "null"]
    },
    "producer_id": {
      "type": "string"
    },
    "price": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Relative price indicator (1–5)"
    },
    "sweetness": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 5
    }
  },
  "required": [
    "name",
    "color",
    "sparkling",
    "minerality",
    "description",
    "acidity",
    "body",
    "vintage",
    "producer_id",
    "price"
  ]
}
