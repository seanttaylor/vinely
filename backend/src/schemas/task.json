{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://example.com/schemas/task-create.json",
  "title": "System Task Creation Request",
  "description": "Schema describing the payload of an incoming POST request to the /tasks endpoint",
  "type": "object",

  "required": ["name"],

  "properties": {
    "name": {
      "type": "string",
      "enum": ["tasks.test.noop"],
      "description": "Identifier of a predefined task"
    },

    "autoStart": {
      "type": "boolean",
      "default": false
    },

    "scheduledAt": {
      "type": "string",
      "description": "ISO Date string representing a future execution time"
    },

    "payload": {
      "type": "object",
      "required": ["body"],
      "properties": {
        "schema": {
          "type": "string",
          "description": "Optional URI to a JSON Patch document"
        },
        "body": {
          "type": "object",
          "description": "Input or seed data for the task"
        },
        "file": {
          "type": "object",
          "description": "An optional file attachment that can be passed to a task"
        }
      },
      "additionalProperties": false
    },

    "attachmentName": {
      "type": "string"
    }
  },

  "additionalProperties": false,

  "allOf": [
    {
      "if": {
        "properties": {
          "autoStart": { "const": true }
        },
        "required": ["autoStart"]
      },
      "then": {
        "not": {
          "required": ["scheduledAt"]
        }
      }
    },
    {
      "if": {
        "required": ["scheduledAt"]
      },
      "then": {
        "properties": {
          "autoStart": false
        }
      }
    }
  ]
}
